        {
            "definition": {
                "title": "Budget Monitors & Alerts",
                "background_color": "custom_green",
                "type": "group",
                "layout_type": "ordered",
                "widgets": [
                    {
                        "definition": {
                            "title": "All cost & billing monitors",
                            "title_size": "13",
                            "type": "manage_status",
                            "display_format": "countsAndList",
                            "color_preference": "text",
                            "hide_zero_counts": false,
                            "show_status": true,
                            "last_triggered_format": "relative",
                            "query": "billing OR spend OR cost OR NAT",
                            "sort": "status,asc",
                            "count": 50,
                            "start": 0,
                            "show_priority": false,
                            "show_last_triggered": true
                        }
                    },
                    {
