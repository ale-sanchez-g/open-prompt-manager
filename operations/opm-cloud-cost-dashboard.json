                                        }
                                    ],
                                    "display_type": "line"
                                }
                            ],
                            "markers": [
                                { "value": "y = 30", "display_type": "ok dashed",      "label": "right-size floor 30%" },
                                { "value": "y = 80", "display_type": "warning dashed", "label": "scale-out warn 80%"   },
                                { "value": "y = 90", "display_type": "error dashed",   "label": "alert 90%"            }
