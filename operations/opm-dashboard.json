{
    "title": "Open Prompt Manager — Platform Snapshot",
    "description": "Development team dashboard — ECS infrastructure, ALB traffic, synthetic health, monitor status, and quality engineering scorecard. Generated 2026-04-24.",
    "widgets": [

        {
            "definition": {
                "title": "OPM — At a glance",
                "background_color": "custom_blue",
                "type": "group",
                "layout_type": "ordered",
                "widgets": [
                    {
                        "definition": {
                            "title": "Monitor status",
                            "title_size": "16",
                            "type": "manage_status",
                            "display_format": "countsAndList",
                            "color_preference": "text",
                            "hide_zero_counts": false,
                            "show_status": true,
                            "last_triggered_format": "relative",
                            "query": "OPM",
                            "sort": "status,asc",
                            "count": 50,
                            "start": 0,
                            "show_priority": false,
                            "show_last_triggered": true
                        }
                    },
                    {
                        "definition": {
                            "title": "Backend tasks — running / desired",
                            "title_size": "16",
                            "title_align": "left",
                            "time": { "live_span": "5m" },
                            "type": "query_value",
                            "requests": [
                                {
                                    "conditional_formats": [
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_green", "value": 1 },
                                        { "hide_value": false, "comparator": "<",  "palette": "white_on_red",   "value": 1 }
                                    ],
                                    "formulas": [{ "formula": "running / desired * 100" }],
                                    "queries": [
                                        { "data_source": "metrics", "name": "running", "query": "avg:aws.ecs.service.running{service:open-prompt-manager-backend}" },
                                        { "data_source": "metrics", "name": "desired", "query": "avg:aws.ecs.service.desired{service:open-prompt-manager-backend}" }
                                    ],
                                    "response_format": "scalar"
                                }
                            ],
                            "autoscale": true,
                            "custom_unit": "%",
                            "precision": 0
                        }
                    },
                    {
                        "definition": {
                            "title": "Frontend tasks — running / desired",
                            "title_size": "16",
                            "title_align": "left",
                            "time": { "live_span": "5m" },
                            "type": "query_value",
                            "requests": [
                                {
                                    "conditional_formats": [
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_green", "value": 1 },
                                        { "hide_value": false, "comparator": "<",  "palette": "white_on_red",   "value": 1 }
                                    ],
                                    "formulas": [{ "formula": "running / desired * 100" }],
                                    "queries": [
                                        { "data_source": "metrics", "name": "running", "query": "avg:aws.ecs.service.running{service:open-prompt-manager-frontend}" },
                                        { "data_source": "metrics", "name": "desired", "query": "avg:aws.ecs.service.desired{service:open-prompt-manager-frontend}" }
                                    ],
                                    "response_format": "scalar"
                                }
                            ],
                            "autoscale": true,
                            "custom_unit": "%",
                            "precision": 0
                        }
                    },
                    {
                        "definition": {
                            "title": "ALB 5xx error rate (5 m)",
                            "title_size": "16",
                            "title_align": "left",
                            "time": { "live_span": "5m" },
                            "type": "query_value",
                            "requests": [
                                {
                                    "conditional_formats": [
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_green", "value": 0 },
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_yellow","value": 1 },
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_red",   "value": 5 }
                                    ],
                                    "formulas": [{ "formula": "clamp_min(errors,0) / clamp_min(requests,1) * 100" }],
                                    "queries": [
                                        { "data_source": "metrics", "name": "errors",   "query": "sum:aws.applicationelb.httpcode_target_5xx{project:open-prompt-manager}.as_count()" },
                                        { "data_source": "metrics", "name": "requests", "query": "sum:aws.applicationelb.request_count{project:open-prompt-manager}.as_count()" }
                                    ],
                                    "response_format": "scalar"
                                }
                            ],
                            "autoscale": true,
                            "custom_unit": "%",
                            "precision": 1
                        }
                    },
                    {
                        "definition": {
                            "title": "Synthetic healthcheck",
                            "title_size": "16",
                            "title_align": "left",
                            "time": { "live_span": "15m" },
                            "type": "query_value",
                            "requests": [
                                {
                                    "conditional_formats": [
                                        { "hide_value": false, "comparator": ">=", "palette": "white_on_green", "value": 1 },
                                        { "hide_value": false, "comparator": "<",  "palette": "white_on_red",   "value": 1 }
                                    ],
                                    "formulas": [{ "formula": "q" }],
                                    "queries": [
                                        { "data_source": "metrics", "name": "q", "query": "avg:synthetics.test_runs{url:https://opm-dx1.com/api/ready}.as_count()" }
                                    ],
                                    "response_format": "scalar"
                                }
                            ],
                            "autoscale": true,
                            "precision": 0
                        }
                    },
                    {
                        "definition": {
                            "type": "note",
                            "content": "## Quality Score: **64 / D**\n\n| Dimension | Score |\n|---|---|\n| Codebase Health | 70 C |\n| Security & Compliance | 72 C |\n| Reliability & Stability | 68 C |\n| User-Centric Quality | 60 D |\n| Workflow & Efficiency | 68 C |\n| Architecture & Design | 58 F |\n| Delivery Flow & DORA | 72 C |\n| **Operational Excellence** | **42 F** |\n\n_Updated 2026-04-24. Next priority: APM + log ingestion._",
                            "background_color": "white",
                            "font_size": "12",
                            "text_align": "left",
                            "show_tick": false,
                            "has_padding": true
                        }
                    }
                ]
            }
        },

